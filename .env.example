# Copy this file to .env and fill in real values. Never commit .env.

# ── backend (Spring Boot) ───────────────────────────────────────────────
# data.go.kr 국토부 실거래가 서비스키 — use the ENCODING variant.
DATA_GO_KR_SERVICE_KEY=your-data-go-kr-encoding-service-key

# PostgreSQL connection (Railway / Neon / Supabase) — used by the `prod` profile.
# Local dev defaults to in-memory H2, so these can stay empty.
DATABASE_URL=jdbc:postgresql://host:5432/siseradar
DB_USERNAME=
DB_PASSWORD=

# JWT
JWT_SECRET=replace-with-a-long-random-base64-secret
JWT_EXPIRATION_SECONDS=3600

# server / CORS
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://siseradar.vercel.app

# v2 only — Kakao address search for geocoding the map
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Google Gemini (free Flash tier) — AI 시장 요약. 비우면 템플릿 요약으로 폴백.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
# v2 only — Kakao Maps JS SDK key
VITE_KAKAO_MAP_KEY=your-kakao-maps-js-key

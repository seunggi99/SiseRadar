# Copy this file to .env and fill in real values. Never commit .env.

# ── backend (Spring Boot) ───────────────────────────────────────────────
# data.go.kr 국토부 실거래가 서비스키 — 수집은 ENCODING 키 사용.
DATA_GO_KR_SERVICE_KEY=your-data-go-kr-encoding-service-key
# (선택) DECODING 키 — 진단/폴백용. URL에 넣을 때 URL-encode 필요.
DATA_GO_KR_SERVICE_DECODING_KEY=your-data-go-kr-decoding-service-key

# PostgreSQL connection (Railway / Neon / Supabase) — used by the `prod` profile.
# Local dev defaults to in-memory H2, so these can stay empty.
DATABASE_URL=jdbc:postgresql://host:5432/siseradar
DB_USERNAME=
DB_PASSWORD=

# railway 프로파일 — 로컬에서 원격 Railway DB로 백필할 때만.
# 실행: cd backend && ./gradlew bootRun --args='--spring.profiles.active=railway'
# url은 반드시 JDBC 형식(jdbc:postgresql://...). Railway의 postgresql:// 원형은 변환해서 넣기.
RAILWAY_DB_URL=jdbc:postgresql://host:5432/railway?sslmode=require
RAILWAY_DB_USERNAME=
RAILWAY_DB_PASSWORD=

# JWT
JWT_SECRET=replace-with-a-long-random-base64-secret
JWT_EXPIRATION_SECONDS=3600

# server / CORS
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://siseradar.vercel.app

# v2 only — Kakao address search for geocoding the map
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Google Gemini (free Flash tier) — AI 시장 요약. 비우면 템플릿 요약으로 폴백.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── frontend (Vite) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
# v2 only — Kakao Maps JS SDK key
VITE_KAKAO_MAP_KEY=your-kakao-maps-js-key
